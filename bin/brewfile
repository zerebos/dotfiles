#!/usr/bin/env bash

set -euo pipefail

BREWFILE_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/yadm/brewfiles"

usage() {
    echo "Usage:"
    echo "  brewfile list"
    echo "  brewfile install <name> [<name> ...] [--dry-run]"
    echo "  brewfile view <name>"
    echo "  brewfile search <query>"
    exit 1
}

list_brewfiles() {
    echo "Available Brewfiles:"
    for f in "$BREWFILE_DIR"/*.rb; do
        basename "${f%.rb}"
    done
}

brewfile_path() {
    echo "$BREWFILE_DIR/$1.rb"
}

install_brewfiles() {
    local dry_run=false
    local names=()

    # Parse args
    for arg in "$@"; do
        case "$arg" in
            --dry-run) dry_run=true ;;
            *) names+=("$arg") ;;
        esac
    done

    if [[ ${#names[@]} -eq 0 ]]; then
        echo "No Brewfiles specified."
        list_brewfiles
        exit 1
    fi

    for name in "${names[@]}"; do
        local file
        file=$(brewfile_path "$name")

        if [[ ! -f "$file" ]]; then
            echo "Error: Brewfile '$name.rb' not found."
            list_brewfiles
            continue
        fi

        echo "Installing from: $file"
        if [[ "$dry_run" = true ]]; then
            brew bundle --file="$file" --no-upgrade
        else
            brew bundle --file="$file"
        fi
    done
}

